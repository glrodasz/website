{
  "name": "website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:tokens": "tsx src/tokens/build-tokens.ts",
    "build:posts": "tsx scripts/build-posts.ts",
    "build:covers": "tsx scripts/download-covers.ts",
    "dev": "npm run build:tokens && npm run build:posts && vite",
    "build": "npm run build:tokens && npm run build:posts && tsc -b && vite build && storybook build --output-dir dist/components",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "npm run build:tokens && npm run build:posts && storybook dev -p 6006",
    "build-storybook": "npm run build:tokens && npm run build:posts && storybook build"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "phosphor-react": "^1.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "^10.1.8",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-onboarding": "^10.1.8",
    "@storybook/addon-vitest": "^10.1.8",
    "@storybook/react-vite": "^10.1.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "@types/three": "^0.183.1",
    "@vercel/node": "^5.7.4",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.1.8",
    "fast-xml-parser": "^5.5.9",
    "globals": "^16.5.0",
    "playwright": "^1.57.0",
    "sharp": "^0.34.5",
    "storybook": "^10.1.8",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
